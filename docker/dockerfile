# docker/Dockerfile
# -----------------
FROM python:3.11-slim

# metadata
LABEL org.opencontainers.image.source="your-repo"
ENV PYTHONDONTWRITEBYTECODE=1
ENV PYTHONUNBUFFERED=1

# system deps for psycopg / building wheels
RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential gcc libpq-dev curl netcat \
    && rm -rf /var/lib/apt/lists/*

# create non-root user
ARG APP_USER=appuser
ARG APP_UID=1000
RUN groupadd -g ${APP_UID} ${APP_USER} || true \
    && useradd -m -u ${APP_UID} -g ${APP_UID} -s /bin/bash ${APP_USER}

WORKDIR /usr/src/app

# install requirements first for cache layer
COPY requirements.txt /usr/src/app/
RUN pip install --upgrade pip setuptools wheel \
    && pip install -r requirements.txt

# copy application
COPY . /usr/src/app
RUN chown -R ${APP_USER}:${APP_USER} /usr/src/app

USER ${APP_USER}

# expose ports (API + TCP)
EXPOSE 8000 5023

# default command (override in compose for different processes)
CMD ["uvicorn", "app.main:app", "--host", "0.0.0.0", "--port", "8000", "--workers", "1"]
